APP_ENV=development
APP_NAME=stock-agent-ai
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

POSTGRES_DB=stock_agent
POSTGRES_USER=stock
POSTGRES_PASSWORD=stock
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+psycopg2://stock:stock@postgres:5432/stock_agent

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_ANALYSIS_QUEUE=stock-analysis-requests

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_REASONING_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
VECTOR_BACKEND=qdrant
VECTOR_COLLECTION_NAME=stock_knowledge
CHROMA_PERSIST_DIRECTORY=runtime/chroma

MARKET_DATA_CACHE_TTL_SECONDS=300
PREDICTION_MODEL_PATH=models/stock_trending_model.pt
PREDICTION_SEQUENCE_LENGTH=30
RAG_ENABLED=false
LOGS_DIR=runtime/logs
